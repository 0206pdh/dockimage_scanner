# 안 좋은 Python Dockerfile 예시 — imgadvisor 테스트용
FROM python:3.11

WORKDIR /app

# 빌드 도구 설치 (런타임에 불필요)
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    build-essential \
    libpq-dev \
    git \
    curl

# 캐시 정리 없음, --no-cache-dir 없음
RUN pip install fastapi uvicorn sqlalchemy psycopg2

# 전체 디렉터리 복사 (.dockerignore 없음)
COPY . .

EXPOSE 8000
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
